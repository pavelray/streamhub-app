{
  "name": "streamhub-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "electron_main": "electron/main.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "electron:dev": "concurrently \"expo start --web --port 8081\" \"wait-on http://localhost:8081 && electron electron/main.js\"",
    "electron:build": "expo export --platform web && electron-builder --config"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.46",
    "expo-blur": "~14.0.1",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.14",
    "expo-haptics": "~14.0.1",
    "expo-image": "~2.0.7",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.21",
    "expo-status-bar": "~2.0.1",
    "groq-sdk": "^1.1.2",
    "lucide-react-native": "^0.475.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.5",
    "slugify": "^1.6.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.3.3",
    "wait-on": "^9.0.4"
  },
  "private": true
}
