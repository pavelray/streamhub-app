{
  "name": "streamhub-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "electron_main": "electron/main.js",
  "scripts": {
    "start": "expo start",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "electron:dev": "concurrently \"expo start --web --port 8081\" \"wait-on http://localhost:8081 && electron electron/main.js\"",
    "electron:build": "expo export --platform web && electron-builder --config"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.7",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.9",
    "expo-blur": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "groq-sdk": "^1.1.2",
    "lucide-react-native": "^0.475.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.16.1",
    "slugify": "^1.6.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.3",
    "wait-on": "^9.0.4"
  },
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  }
}
